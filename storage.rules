rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ── Voice notes ────────────────────────────────────────────────────────────
    match /families/{familyId}/children/{childId}/voiceNotes/{fileName} {
      // Only authenticated family members can read/write voice notes for this family
      allow read: if request.auth != null &&
        exists(/databases/(default)/documents/families/$(familyId)/parents/$(request.auth.uid));

      allow write: if request.auth != null &&
        exists(/databases/(default)/documents/families/$(familyId)/parents/$(request.auth.uid)) &&
        request.resource.size < 10 * 1024 * 1024 &&  // max 10 MB
        request.resource.contentType.matches('audio/.*');

      allow delete: if request.auth != null &&
        exists(/databases/(default)/documents/families/$(familyId)/parents/$(request.auth.uid));
    }

    // ── Deny everything else ───────────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
